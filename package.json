{
  "name": "bloom-website",
  "version": "1.0.0",
  "description": "Bloom - A student-led social impact initiative website",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security-audit": "npm audit --audit-level=high",
    "check-circular": "madge --circular --extensions ts,tsx app lib",
    "check-unused": "depcheck --ignores=\"postcss,autoprefixer,@commitlint/config-conventional,@types/*,@typescript-eslint/*\"",
    "commitlint": "commitlint --from=master"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.18",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.17.0",
    "mongoose": "^8.1.1",
    "next": "^15.1.8",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^6.0.2",
    "depcheck": "^1.4.7",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.1.1",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
