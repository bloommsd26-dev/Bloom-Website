{
  "name": "bloom-website",
  "version": "1.0.0",
  "description": "Bloom - A student-led social impact initiative website",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security-audit": "npm audit --audit-level=high",
    "check-circular": "madge --circular --extensions ts,tsx app lib",
    "check-unused": "depcheck --ignores=\"postcss,autoprefixer,@commitlint/config-conventional,@types/*,@typescript-eslint/*\"",
    "commitlint": "commitlint --from=master"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.18",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "next": "^15.1.8",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.1.0",
    "madge": "^8.0.0",
    "prettier": "^3.1.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
